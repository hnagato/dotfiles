#!/bin/bash

SIGNING_ENABLED=$(git config --bool --get commit.gpgsign || echo false)
if [ "$SIGNING_ENABLED" != "true" ]; then
  echo "❌ Git commit signing is disabled. Set commit.gpgsign=true before committing."
  exit 1
fi

LOCAL_SIGNING=$(git config --local --bool --get commit.gpgsign 2>/dev/null || true)
if [ "$LOCAL_SIGNING" = "false" ]; then
  echo "❌ Repository-local commit.gpgsign=false overrides the global signing policy."
  echo "   Run: git config --local --unset commit.gpgsign"
  exit 1
fi

if ! git config --get user.signingkey >/dev/null; then
  echo "❌ Git user.signingkey is not configured. Configure a signing key before committing."
  exit 1
fi

echo "🔍 Running gitleaks security check..."
if ! gitleaks protect --staged; then
  echo "❌ Gitleaks detected potential secrets. Commit blocked."
  exit 1
fi

GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
LOCAL_HOOK="${GIT_ROOT}/.git/hooks/pre-commit"

if [ -f "$LOCAL_HOOK" ] && [ "$LOCAL_HOOK" != "$0" ]; then
  echo "🔧 Running repository-specific pre-commit hook..."
  if [ -x "$LOCAL_HOOK" ]; then
    "$LOCAL_HOOK" || exit $?
  else
    echo "⚠️ Local hook exists but is not executable: $LOCAL_HOOK"
  fi
fi

echo "✅ All pre-commit checks passed."
